<Page x:Class="GroupProjectPrn212.Views.CaHocView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ca học"
      Background="#F3F4F6">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc" Style="{StaticResource GroupTitleStyle}"/>
                    <WrapPanel>
                        <TextBox x:Name="txtKeyword" Width="280" Style="{StaticResource InputTextBoxStyle}"/><Button Content="Tìm kiếm" Click="btnSearch_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120"/><Button Content="Làm mới" Click="btnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin ca học" Style="{StaticResource GroupTitleStyle}"/>

<Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="Mã ca" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtMaCa" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Giờ bắt đầu (HH:mm)" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtGioBatDau" Style="{StaticResource InputTextBoxStyle}"/>
    </StackPanel>
    <StackPanel Grid.Column="1">
        <TextBlock Text="Tên ca" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtTenCa" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Giờ kết thúc (HH:mm)" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtGioKetThuc" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtGhiChu" Style="{StaticResource InputTextBoxStyle}"/>
    </StackPanel>
</Grid>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="btnAdd" Content="Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnUpdate" Content="Sửa" Click="btnUpdate_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnDelete" Content="Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButtonStyle}" Width="110"/>
                        <Button x:Name="btnClear" Content="Clear" Click="btnClear_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Danh sách ca học" Style="{StaticResource GroupTitleStyle}"/>
                    <DataGrid x:Name="dgCaHoc" SelectionChanged="dgCaHoc_SelectionChanged">
                        <DataGrid.Columns>

<DataGridTextColumn Header="ID" Binding="{Binding CaHocId}" Width="70"/>
<DataGridTextColumn Header="Mã" Binding="{Binding MaCa}" Width="120"/>
<DataGridTextColumn Header="Tên ca" Binding="{Binding TenCa}" Width="*"/>
<DataGridTextColumn Header="Giờ bắt đầu" Binding="{Binding GioBatDau}" Width="120"/>
<DataGridTextColumn Header="Giờ kết thúc" Binding="{Binding GioKetThuc}" Width="120"/>
<DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="180"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
