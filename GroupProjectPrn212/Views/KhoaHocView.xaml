<Page x:Class="GroupProjectPrn212.Views.KhoaHocView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Khóa học"
      Background="#F3F4F6">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc" Style="{StaticResource GroupTitleStyle}"/>
                    <WrapPanel>
                        <TextBox x:Name="txtKeyword" Width="280" Style="{StaticResource InputTextBoxStyle}"/><Button Content="Tìm kiếm" Click="btnSearch_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120"/><Button Content="Làm mới" Click="btnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin khóa học" Style="{StaticResource GroupTitleStyle}"/>

<Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="Mã khóa học" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtMaKhoaHoc" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Loại khóa học" Style="{StaticResource FieldLabelStyle}"/>
        <ComboBox x:Name="cbLoaiKhoaHoc" Style="{StaticResource InputComboBoxStyle}">
            <ComboBoxItem Content="Tin học"/>
            <ComboBoxItem Content="Ngoại ngữ"/>
        </ComboBox>
        <TextBlock Text="Học phí" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtHocPhi" Style="{StaticResource InputTextBoxStyle}"/>
    </StackPanel>
    <StackPanel Grid.Column="1">
        <TextBlock Text="Tên khóa học" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtTenKhoaHoc" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Thời lượng" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtThoiLuong" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Mô tả" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtMoTa" Style="{StaticResource InputTextBoxStyle}"/>
    </StackPanel>
</Grid>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="btnAdd" Content="Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnUpdate" Content="Sửa" Click="btnUpdate_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnDelete" Content="Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButtonStyle}" Width="110"/>
                        <Button x:Name="btnClear" Content="Clear" Click="btnClear_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Danh sách khóa học" Style="{StaticResource GroupTitleStyle}"/>
                    <DataGrid x:Name="dgKhoaHoc" SelectionChanged="dgKhoaHoc_SelectionChanged">
                        <DataGrid.Columns>

<DataGridTextColumn Header="ID" Binding="{Binding KhoaHocId}" Width="70"/>
<DataGridTextColumn Header="Mã" Binding="{Binding MaKhoaHoc}" Width="120"/>
<DataGridTextColumn Header="Tên khóa" Binding="{Binding TenKhoaHoc}" Width="*"/>
<DataGridTextColumn Header="Loại" Binding="{Binding LoaiKhoaHoc}" Width="120"/>
<DataGridTextColumn Header="Học phí" Binding="{Binding HocPhi}" Width="130"/>
<DataGridTextColumn Header="Thời lượng" Binding="{Binding ThoiLuong}" Width="100"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
