<Page x:Class="GroupProjectPrn212.Views.TaiKhoanView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tài khoản"
      Background="#F3F4F6">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc" Style="{StaticResource GroupTitleStyle}"/>
                    <WrapPanel>
                        <TextBox x:Name="txtKeyword" Width="280" Style="{StaticResource InputTextBoxStyle}"/><Button Content="Tìm kiếm" Click="btnSearch_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120"/><Button Content="Làm mới" Click="btnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin tài khoản" Style="{StaticResource GroupTitleStyle}"/>

<Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="Tên đăng nhập" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtTenDangNhap" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Họ tên" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtHoTen" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Vai trò" Style="{StaticResource FieldLabelStyle}"/>
        <ComboBox x:Name="cbVaiTro" Style="{StaticResource InputComboBoxStyle}">
            <ComboBoxItem Content="Admin"/>
            <ComboBoxItem Content="NhanVien"/>
        </ComboBox>
    </StackPanel>
    <StackPanel Grid.Column="1">
        <TextBlock Text="Mật khẩu" Style="{StaticResource FieldLabelStyle}"/>
        <PasswordBox x:Name="txtMatKhau" Style="{StaticResource InputPasswordBoxStyle}"/>
        <TextBlock Text="Trạng thái" Style="{StaticResource FieldLabelStyle}"/>
        <ComboBox x:Name="cbTrangThai" Style="{StaticResource InputComboBoxStyle}">
            <ComboBoxItem Content="True"/>
            <ComboBoxItem Content="False"/>
        </ComboBox>
    </StackPanel>
</Grid>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="btnAdd" Content="Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnUpdate" Content="Sửa" Click="btnUpdate_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnDelete" Content="Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButtonStyle}" Width="110"/>
                        <Button x:Name="btnClear" Content="Clear" Click="btnClear_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Danh sách tài khoản" Style="{StaticResource GroupTitleStyle}"/>
                    <DataGrid x:Name="dgTaiKhoan" SelectionChanged="dgTaiKhoan_SelectionChanged">
                        <DataGrid.Columns>

<DataGridTextColumn Header="ID" Binding="{Binding TaiKhoanId}" Width="70"/>
<DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding TenDangNhap}" Width="150"/>
<DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="*"/>
<DataGridTextColumn Header="Vai trò" Binding="{Binding VaiTro}" Width="120"/>
<DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="100"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
