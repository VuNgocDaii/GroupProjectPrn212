<Page x:Class="GroupProjectPrn212.Views.PhongHocView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Phòng học"
      Background="#F3F4F6">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc" Style="{StaticResource GroupTitleStyle}"/>
                    <WrapPanel>
                        <TextBox x:Name="txtKeyword" Width="280" Style="{StaticResource InputTextBoxStyle}"/><Button Content="Tìm kiếm" Click="btnSearch_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120"/><Button Content="Làm mới" Click="btnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin phòng học" Style="{StaticResource GroupTitleStyle}"/>

<Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="Mã phòng" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtMaPhong" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Sức chứa" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtSucChua" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Trạng thái" Style="{StaticResource FieldLabelStyle}"/>
        <ComboBox x:Name="cbTrangThai" Style="{StaticResource InputComboBoxStyle}">
            <ComboBoxItem Content="Hoạt động"/>
            <ComboBoxItem Content="Bảo trì"/>
        </ComboBox>
    </StackPanel>
    <StackPanel Grid.Column="1">
        <TextBlock Text="Tên phòng" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtTenPhong" Style="{StaticResource InputTextBoxStyle}"/>
        <TextBlock Text="Loại phòng" Style="{StaticResource FieldLabelStyle}"/>
        <ComboBox x:Name="cbLoaiPhong" Style="{StaticResource InputComboBoxStyle}">
            <ComboBoxItem Content="Lý thuyết"/>
            <ComboBoxItem Content="Máy tính"/>
            <ComboBoxItem Content="Ngoại ngữ"/>
        </ComboBox>
        <TextBlock Text="Mô tả" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox x:Name="txtMoTa" Style="{StaticResource InputTextBoxStyle}"/>
    </StackPanel>
</Grid>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="btnAdd" Content="Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnUpdate" Content="Sửa" Click="btnUpdate_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnDelete" Content="Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButtonStyle}" Width="110"/>
                        <Button x:Name="btnClear" Content="Clear" Click="btnClear_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Danh sách phòng học" Style="{StaticResource GroupTitleStyle}"/>
                    <DataGrid x:Name="dgPhongHoc" SelectionChanged="dgPhongHoc_SelectionChanged">
                        <DataGrid.Columns>

<DataGridTextColumn Header="ID" Binding="{Binding PhongHocId}" Width="70"/>
<DataGridTextColumn Header="Mã" Binding="{Binding MaPhong}" Width="120"/>
<DataGridTextColumn Header="Tên phòng" Binding="{Binding TenPhong}" Width="*"/>
<DataGridTextColumn Header="Sức chứa" Binding="{Binding SucChua}" Width="100"/>
<DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong}" Width="120"/>
<DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
