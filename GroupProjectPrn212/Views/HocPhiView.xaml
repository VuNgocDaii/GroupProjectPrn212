<Page x:Class="GroupProjectPrn212.Views.HocPhiView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Học phí"
      Background="#F3F4F6">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc" Style="{StaticResource GroupTitleStyle}"/>
                    <WrapPanel>
                        <TextBox x:Name="txtKeyword" Width="280" Style="{StaticResource InputTextBoxStyle}"/>
                        <Button Content="Lọc chưa đóng" Click="btnSearch_Click" Style="{StaticResource PrimaryButtonStyle}" Width="140"/>
                        <Button Content="Làm mới" Click="btnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin học phí" Style="{StaticResource GroupTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Đăng ký" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="cbDangKy"
                                      SelectedValuePath="DangKyId"
                                      Style="{StaticResource InputComboBoxStyle}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Số tiền" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtSoTien" Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Ngày thu" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker x:Name="dpNgayThu" Style="{StaticResource InputDatePickerStyle}"/>

                            <TextBlock Text="Trạng thái thanh toán" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="cbTrangThai" Style="{StaticResource InputComboBoxStyle}">
                                <ComboBoxItem Content="Đã đóng"/>
                                <ComboBoxItem Content="Chưa đóng"/>
                                <ComboBoxItem Content="Cọc"/>
                            </ComboBox>

                            <Button Content="Đánh dấu đã đóng" Click="btnMarkPaid_Click" Style="{StaticResource PrimaryButtonStyle}" Width="150"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="btnAdd" Content="Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnUpdate" Content="Sửa" Click="btnUpdate_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                        <Button x:Name="btnDelete" Content="Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButtonStyle}" Width="110"/>
                        <Button x:Name="btnClear" Content="Clear" Click="btnClear_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Danh sách học phí" Style="{StaticResource GroupTitleStyle}"/>
                    <DataGrid x:Name="dgHocPhi" SelectionChanged="dgHocPhi_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding HocPhiId}" Width="70"/>
                            <DataGridTextColumn Header="Học viên" Binding="{Binding HocVienTen}" Width="180"/>
                            <DataGridTextColumn Header="Lớp học" Binding="{Binding LopHocTen}" Width="220"/>
                            <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien}" Width="140"/>
                            <DataGridTextColumn Header="Ngày thu" Binding="{Binding NgayThu}" Width="130"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThaiThanhToan}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
