<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#2563EB"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="#E5E7EB"/>
        <Setter Property="Foreground" Value="#111827"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="#DC2626"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#DC2626"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Margin" Value="0,4,0,10"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
    </Style>

    <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Margin" Value="0,4,0,10"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
    </Style>

    <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Margin" Value="0,4,0,10"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
    </Style>

    <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Margin" Value="0,4,0,10"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#111827"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="RowHeight" Value="34"/>
        <Setter Property="ColumnHeaderHeight" Value="38"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
