<Window x:Class="GroupProjectPrn212.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập" Height="430" Width="740"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1E3A8A">
            <StackPanel VerticalAlignment="Center" Margin="36">
                <TextBlock Text="TRUNG TÂM ĐÀO TẠO"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Quản lý tin học - ngoại ngữ"
                           Margin="0,12,0,0"
                           Foreground="#DBEAFE"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="28" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Đăng nhập hệ thống" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>
                <TextBlock Text="Tên đăng nhập" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource InputTextBoxStyle}"/>

                <TextBlock Text="Mật khẩu" Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource InputPasswordBoxStyle}"/>

                <Button x:Name="btnLogin" Content="Đăng nhập" Click="btnLogin_Click"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,8,0,0"/>
                <TextBlock x:Name="txtMessage" Foreground="#DC2626" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
